const eventSchema = {"@context": "https://schema.org", "@type": "Event", "name": "JAGATRIP #2 — Beijing & Hangzhou Education Mission", "startDate": "2026-09-11", "endDate": "2026-09-17", "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode", "eventStatus": "https://schema.org/EventScheduled", "location": [{"@type": "Place", "name": "Beijing, China"}, {"@type": "Place", "name": "Hangzhou, China"}], "organizer": {"@type": "Organization", "name": "PT Jagatrip Mitra Edukasi", "url": "https://jagatrip.com"}};
---

<BaseLayout title="JAGATRIP #2 — Education Mission ke Beijing & Hangzhou" description="Program studi banding pendidikan ke Beijing & Hangzhou, 11–17 September 2026. Dua expo internasional, kunjungan sekolah, kuota 20 peserta." canonical="https://jagatrip.com/china2" ogType="website" extraSchemas={[eventSchema]}>







<nav class="nav" role="navigation" aria-label="Utama">
  <div class="nav-inner">
    <a href="/" class="logo-wrap" aria-label="JAGATRIP"><img class="brand-logo" src="/images/china/jagatrip-logo.png" width="2094" height="570" alt="JAGATRIP Mitra Edukasi"></a>
    <a href="#form" class="nav-cta">Daftar Minat →</a>
  </div>
</nav>

<main id="main">


<section class="hero" id="hero" aria-label="Hero">
  <div class="hero-inner">
    <div class="hero-eyebrow">COMING UP EVENT · JAGATRIP #2</div>
    <h1>Beijing &amp; Hangzhou <span class="accent">Education Mission</span></h1>
    <p class="hero-sub">Kelas global untuk pemimpin pendidikan Indonesia</p>
    <p class="hero-body">Tujuh hari di dua kota, dua pameran pendidikan internasional, dan ruang kelas sekolah Tiongkok yang biasanya tertutup untuk pengunjung biasa. Ini bukan tur wisata dengan tempelan agenda pendidikan — ini perjalanan belajar yang dirancang untuk praktisi.</p>

    <div class="hero-badge" role="group">
      <div>
        <div style="font-size:11px; letter-spacing:1.5px; color:var(--muted); font-weight:800;">TANGGAL</div>
        <div>11 – 17 September 2026</div>
      </div>
      <div class="divider"></div>
      <div>
        <div style="font-size:11px; letter-spacing:1.5px; color:var(--muted); font-weight:800;">DURASI</div>
        <div>7 Hari</div>
      </div>
      <div class="china-dot" aria-hidden="true"></div>
    </div>

    <div class="hero-ctas">
      <a href="#form" class="btn-primary" data-track="click_cta_hero">Daftar Minat Sekarang →</a>
      <a href="#form" class="btn-wa-hero" data-track="click_whatsapp" data-loc="hero">Ajukan Minat →</a>
    </div>
    <div class="hero-micro">Kuota 20 peserta. Pendaftar awal masuk daftar prioritas.</div>
  </div>
</section>


<section class="trust-strip" aria-label="Fakta cepat">
  <div class="trust-inner">
    <div class="trust-item">
      <span class="num">7 <small>hari</small></span>
      <div class="lbl">Durasi program · 11–17 Sep 2026</div>
    </div>
    <div class="trust-item">
      <span class="num">2 <small>kota</small></span>
      <div class="lbl">Beijing &amp; Hangzhou · kereta cepat ±4,5 jam</div>
    </div>
    <div class="trust-item">
      <span class="num">2 <small>expo</small></span>
      <div class="lbl">CIFTIS 2026 &amp; Worlddidac Asia 2026</div>
    </div>
    <div class="trust-item">
      <span class="num">20 <small>kursi</small></span>
      <div class="lbl">Kuota terbatas · prioritas pendaftar awal</div>
    </div>
  </div>
</section>


<section id="kenapa" aria-label="Kenapa JAGATRIP 2 berbeda">
  <div class="section-inner">
    <div class="eyebrow">KENAPA JAGATRIP #2 BERBEDA</div>
    <h2>Dari ASEAN, sekarang ke kelas global</h2>
    <p class="lead">Edisi pertama membawa kami ke Malaysia dan Thailand. Edisi kedua bukan sekadar pindah negara — ini pindah skala.</p>

    <div class="why-cards">
      <article class="why-card">
        <div class="why-num">01</div>
        <h3>Dua expo pendidikan internasional</h3>
        <p>CIFTIS di Beijing, pameran berskala pemerintah Tiongkok. Worlddidac Asia di Hangzhou, pameran teknologi pendidikan terbesar di Asia. Dua-duanya, dalam satu perjalanan tujuh hari.</p>
      </article>
      <article class="why-card">
        <div class="why-num">02</div>
        <h3>Masuk ke ruang kelasnya</h3>
        <p>Pameran bisa dimasuki siapa saja yang mendaftar. Duduk di ruang kepala sekolah Beijing dan bertanya langsung soal kurikulum mereka — itu yang tidak dijual di loket mana pun. JAGATRIP mengaturnya untuk Anda.</p>
      </article>
      <article class="why-card">
        <div class="why-num">03</div>
        <h3>Jaringan yang terbawa pulang</h3>
        <p>Anda akan bertemu perusahaan edtech, perwakilan universitas, dan pendidik dari puluhan negara. Yang paling berharga dari perjalanan ini sering baru terasa enam bulan setelah pulang, ketika satu nama di kartu nama berubah menjadi kerja sama.</p>
      </article>
    </div>
  </div>
</section>


<section class="cities" id="dua-kota" aria-label="Dua kota">
  <div class="section-inner">
    <div class="eyebrow">PETA PERJALANAN</div>
    <h2>Dua kota, satu benang merah</h2>
    <p class="lead">Beijing bicara kebijakan dan skala. Hangzhou bicara teknologi dan praktik. Kami menyambungkan keduanya dengan kereta cepat.</p>

    <div class="cities-grid">
      <div class="city-panel city-beijing">
        <div class="city-tag">11 – 14 SEPTEMBER · BEIJING</div>
        <h3>BEIJING</h3>
        <div class="cn-name" aria-hidden="true">北京 · Ibukota Kebijakan</div>
        <ul>
          <li>CIFTIS 2026 — education expo berskala pemerintah</li>
          <li>Kunjungan 2–4 sekolah</li>
          <li>Forum kebijakan &amp; business matching</li>
        </ul>
      </div>

      <div class="city-connector" aria-hidden="true">
        <div class="city-pill">
          <span class="train">🚄</span>
          <div>High-Speed Rail<br>Beijing → Hangzhou</div>
          <div class="time">±4,5 jam</div>
        </div>
      </div>

      <div class="city-panel city-hangzhou">
        <div class="city-tag">14 – 17 SEPTEMBER · HANGZHOU</div>
        <h3>HANGZHOU</h3>
        <div class="cn-name" aria-hidden="true">杭州 · Basis Teknologi</div>
        <ul>
          <li>Worlddidac Asia 2026</li>
          <li>Kunjungan 1–2 sekolah</li>
          <li>Kota basis teknologi pendidikan Tiongkok</li>
        </ul>
      </div>
    </div>
  </div>
</section>


<section class="highlight-dark" id="ciftis" aria-label="CIFTIS 2026">
  <div class="section-inner">
    <div class="eyebrow">HIGHLIGHT 1 · BEIJING</div>
    <h2>CIFTIS 2026</h2>
    <p class="lead">China International Fair for Trade in Services — Education Services</p>

    <div class="expo-meta">
      <strong>Tanggal &amp; venue:</strong> 9 – 13 September 2026 · Shougang Exhibition Center, Beijing
    </div>

    <div class="stat-cards">
      <div class="stat-card">
        <span class="num">2.400+</span>
        <span class="lbl">exhibitor lintas sektor</span>
        <span class="note">Data penyelenggara CIFTIS</span>
      </div>
      <div class="stat-card">
        <span class="num">110.000 m²</span>
        <span class="lbl">area pameran</span>
        <span class="note">Data penyelenggara CIFTIS</span>
      </div>
      <div class="stat-card">
        <span class="num">±2 hari</span>
        <span class="lbl">rombongan JAGATRIP di expo</span>
        <span class="note">Rombongan hadir 12–13 September</span>
      </div>
    </div>

    <p class="body-quote">Yang kami ambil dari CIFTIS: pavilion smart education dan EdTech, forum kebijakan pendidikan, serta sesi business matching — <strong>ruang di mana Anda bisa duduk langsung dengan universitas dan perusahaan teknologi pendidikan Tiongkok.</strong></p>
    <p class="body-quote" style="margin-top:14px;">Rombongan JAGATRIP hadir pada hari-hari terakhir penyelenggaraan, ketika sesi forum dan business matching berada di puncaknya.</p>
  </div>
</section>


<section class="highlight-cream" id="worlddidac" aria-label="Worlddidac Asia 2026">
  <div class="section-inner">
    <div class="eyebrow">HIGHLIGHT 2 · HANGZHOU</div>
    <h2>Worlddidac Asia 2026</h2>
    <p class="lead">Pameran teknologi pendidikan berskala Asia. Fokus pada praktik yang sedang Anda hadapi hari ini.</p>

    <div class="expo-meta" style="background: rgba(27,73,101,0.08); border-left-color: var(--teal);">
      <strong style="color:var(--teal);">Tanggal &amp; venue:</strong> 15 – 17 September 2026 · Hangzhou Grand Convention Center
    </div>

    <div class="worldd-grid">
      <ul class="worldd-points">
        <li>
          <div class="letter">A</div>
          <div class="txt"><strong>Pameran teknologi pendidikan terbesar di Asia</strong> — 50.000 m², lebih dari 500 exhibitor dari berbagai negara.</div>
        </li>
        <li>
          <div class="letter">B</div>
          <div class="txt"><strong>Fokus tema yang relevan</strong> — EdTech, smart campus, AI dalam pendidikan, dan pendidikan vokasi.</div>
        </li>
        <li>
          <div class="letter">C</div>
          <div class="txt"><strong>Sesi kerja sama internasional</strong> — ruang diskusi kemitraan antar lembaga pendidikan.</div>
        </li>
      </ul>

      <div class="callout-big">
        <div class="num">2</div>
        <div class="gold-line" aria-hidden="true"></div>
        <div class="lbl">HARI PENUH DI<br>WORLDDIDAC ASIA</div>
      </div>
    </div>

    <p class="lead" style="margin-top:32px;">Rombongan hadir 15 dan 16 September, kembali ke Jakarta pada 17 September pagi. <strong style="color:var(--teal);">Dua hari penuh, bukan mampir.</strong></p>
  </div>
</section>


<section id="sekolah" aria-label="Kunjungan sekolah">
  <div class="section-inner">
    <div class="eyebrow">NILAI JUAL PALING LANGKA</div>
    <h2>Bukan cuma pameran — masuk ke sekolahnya</h2>
    <p class="lead">Inti JAGATRIP tetap sama: belajar langsung dari ruang kelas.</p>

    <div class="schools-grid">
      <article class="school-card">
        <span class="count">2 – 4</span>
        <h3>sekolah di Beijing</h3>
        <p>Sekolah dasar hingga menengah, dikoordinasikan bersama partner lokal kami.</p>
      </article>
      <article class="school-card">
        <span class="count">1 – 2</span>
        <h3>sekolah di Hangzhou</h3>
        <p>Kota basis teknologi, sekolah dengan praktik digital yang matang.</p>
      </article>
    </div>

    <div class="format-bar" role="group" aria-label="Format kunjungan">
      <div class="step">Sambutan tuan rumah</div>
      <div class="step">Tur fasilitas</div>
      <div class="step">Dialog terbuka dengan manajemen</div>
      <div class="step">Dokumentasi</div>
      <div class="step">Pertukaran cinderamata</div>
    </div>

    <p class="school-outro">Setiap kunjungan disiapkan dengan surat resmi, penerjemah, dan agenda yang disepakati sebelumnya. Anda datang sebagai delegasi, bukan sebagai turis yang kebetulan lewat.</p>
  </div>
</section>


<section class="itinerary" id="itinerary" aria-label="Kerangka 7 hari">
  <div class="section-inner">
    <div class="eyebrow">KERANGKA 7 HARI</div>
    <h2>Gambaran tujuh hari</h2>
    <p class="lead">Rangkaian masih dalam finalisasi bersama partner. Ini kerangka besarnya.</p>

    <div class="itin-list" id="itinList">
      <div class="itin-item open">
        <button class="itin-summary" type="button" aria-expanded="true">
          <span class="itin-day-badge">HARI 1</span>
          <span class="itin-date">Jum, 11 Sept</span>
          <span class="itin-agenda">Jakarta → Beijing · Welcome briefing</span>
        </button>
        <div class="itin-detail">
          <p>Terbang Jakarta → Beijing. Tiba sore, check-in hotel di area strategis Beijing, welcome briefing rombongan malam hari.</p>
        </div>
      </div>

      <div class="itin-item">
        <button class="itin-summary" type="button" aria-expanded="false">
          <span class="itin-day-badge">HARI 2</span>
          <span class="itin-date">Sab, 12 Sept</span>
          <span class="itin-agenda">Kunjungan sekolah Beijing + CIFTIS sore hari</span>
        </button>
        <div class="itin-detail">
          <p>Kunjungan sekolah Beijing (2 sekolah), lanjut ke CIFTIS sore hari untuk eksplorasi pavilion smart education.</p>
        </div>
      </div>

      <div class="itin-item">
        <button class="itin-summary" type="button" aria-expanded="false">
          <span class="itin-day-badge">HARI 3</span>
          <span class="itin-date">Min, 13 Sept</span>
          <span class="itin-agenda">CIFTIS sehari penuh — exhibition, forum, business matching</span>
        </button>
        <div class="itin-detail">
          <p>Sehari penuh di CIFTIS: exhibition, forum kebijakan, business matching, penutupan expo.</p>
        </div>
      </div>

      <div class="itin-item">
        <button class="itin-summary" type="button" aria-expanded="false">
          <span class="itin-day-badge">HARI 4</span>
          <span class="itin-date">Sen, 14 Sept</span>
          <span class="itin-agenda">Kunjungan sekolah pagi · kereta cepat Beijing → Hangzhou</span>
        </button>
        <div class="itin-detail">
          <p>Kunjungan sekolah pagi. Siang: kereta cepat Beijing → Hangzhou (±4,5 jam). Tiba malam, check-in hotel di Hangzhou.</p>
        </div>
      </div>

      <div class="itin-item">
        <button class="itin-summary" type="button" aria-expanded="false">
          <span class="itin-day-badge">HARI 5</span>
          <span class="itin-date">Sel, 15 Sept</span>
          <span class="itin-agenda">Worlddidac Asia hari pembukaan — keynote &amp; exhibition</span>
        </button>
        <div class="itin-detail">
          <p>Worlddidac Asia hari pembukaan: keynote, exhibition floor, sesi tematik EdTech.</p>
        </div>
      </div>

      <div class="itin-item">
        <button class="itin-summary" type="button" aria-expanded="false">
          <span class="itin-day-badge">HARI 6</span>
          <span class="itin-date">Rab, 16 Sept</span>
          <span class="itin-agenda">Worlddidac Asia hari kedua · sesi kerja sama · farewell dinner</span>
        </button>
        <div class="itin-detail">
          <p>Worlddidac Asia hari kedua: sesi kerja sama internasional, kunjungan sekolah tambahan (opsional), farewell dinner rombongan.</p>
        </div>
      </div>

      <div class="itin-item">
        <button class="itin-summary" type="button" aria-expanded="false">
          <span class="itin-day-badge">HARI 7</span>
          <span class="itin-date">Kam, 17 Sept</span>
          <span class="itin-agenda">Hangzhou → Jakarta · tiba sore hari</span>
        </button>
        <div class="itin-detail">
          <p>Terbang Hangzhou → Jakarta. Tiba sore hari.</p>
        </div>
      </div>
    </div>

    <div class="disclaimer-note">Jadwal dapat berubah menyesuaikan konfirmasi partner dan penyelenggara expo.</div>
  </div>
</section>


<section id="paket" aria-label="Dua opsi paket">
  <div class="section-inner">
    <div class="eyebrow">OPSI PAKET</div>
    <h2>Dua opsi paket, satu pengalaman</h2>
    <p class="lead">Rincian biaya dikirim langsung via WhatsApp setelah Anda menghubungi admin.</p>

    <div class="packages-grid">
      <article class="pkg-card primary">
        <span class="pkg-badge">PAKET LENGKAP</span>
        <h3>Termasuk tiket pesawat Jakarta–Tiongkok PP</h3>
        <p>Termasuk tiket pesawat pulang-pergi Jakarta–Tiongkok, akomodasi hotel 4★ di dua kota (twin sharing), program dua expo, kunjungan sekolah, transportasi darat &amp; kereta cepat, konsumsi (makan siang &amp; malam, restoran halal), pengurusan visa Tiongkok, dan asuransi perjalanan.</p>
        <div class="pkg-price-note">Rincian biaya dikirim via WhatsApp</div>
      </article>
      <article class="pkg-card secondary">
        <span class="pkg-badge">PAKET TANPA TIKET</span>
        <h3>Anda atur penerbangan sendiri</h3>
        <p>Seluruh fasilitas sama, kecuali tiket penerbangan internasional yang Anda atur sendiri. Cocok untuk peserta yang memakai mileage, berangkat dari kota selain Jakarta, atau punya preferensi maskapai tersendiri.</p>
        <div class="pkg-price-note" style="color:var(--teal); background:rgba(27,73,101,0.08);">Rincian biaya dikirim via WhatsApp</div>
      </article>
    </div>

    <div class="packages-bar">
      <div class="packages-bar-txt"><strong>Kuota rombongan: 20 peserta.</strong> Prioritas untuk yang mendaftar lebih awal.</div>
      <a href="#form" class="packages-cta" data-track="click_whatsapp" data-loc="paket">Ajukan Minat →</a>
    </div>
  </div>
</section>


<section class="audience" id="audience" aria-label="Untuk siapa">
  <div class="section-inner">
    <div class="eyebrow">KUALIFIKASI</div>
    <h2>Program ini dirancang untuk</h2>

    <ul class="audience-list">
      <li>Kepala sekolah dan wakil kepala sekolah yang sedang menyusun arah pengembangan lembaga</li>
      <li>Pemilik dan pengurus yayasan pendidikan</li>
      <li>Pengawas, kepala dinas, dan pengambil kebijakan pendidikan daerah</li>
      <li>Dosen, peneliti, dan konsultan pendidikan</li>
      <li>Praktisi EdTech yang mencari mitra dan referensi teknologi dari Asia</li>
    </ul>

    <div class="filter-note">
      <h3>Kalau Anda mencari paket wisata, ini bukan tempatnya</h3>
      <p>Program ini bukan paket wisata. Hari-hari padat, agenda dimulai pagi, dan sebagian besar waktu dihabiskan di ruang pameran serta sekolah. Kami mencari peserta yang datang untuk belajar dan membangun jaringan — bukan untuk berbelanja.</p>
    </div>
  </div>
</section>




<section id="faq" aria-label="Pertanyaan sering ditanyakan">
  <div class="section-inner">
    <div class="eyebrow">FAQ</div>
    <h2>Pertanyaan yang sering masuk</h2>

    <div class="faq-list" id="faqList">
      <div class="faq-item">
        <button class="faq-q" type="button" aria-expanded="false">Berapa biayanya?</button>
        <div class="faq-a"><p>Rincian biaya kami kirim langsung via WhatsApp. Ada dua opsi paket — dengan dan tanpa tiket penerbangan internasional. Hubungi admin dan kami kirimkan perinciannya lengkap.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button" aria-expanded="false">Apakah visa diurus oleh JAGATRIP?</button>
        <div class="faq-a"><p>Ya. Pengurusan visa Tiongkok termasuk dalam kedua paket. Anda cukup menyiapkan dokumen, tim kami yang memproses. Proses visa membutuhkan 4–10 hari kerja, jadi pendaftaran ditutup jauh sebelum keberangkatan.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button" aria-expanded="false">Sekolah mana saja yang akan dikunjungi?</button>
        <div class="faq-a"><p>Masih dalam koordinasi dengan partner kami di Beijing dan Hangzhou. Yang bisa kami pastikan sekarang adalah jumlahnya: 2–4 sekolah di Beijing, 1–2 sekolah di Hangzhou. Nama sekolah diumumkan kepada peserta terdaftar begitu konfirmasi keluar.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button" aria-expanded="false">Bagaimana dengan makanan halal?</button>
        <div class="faq-a"><p>Seluruh konsumsi rombongan diatur di restoran halal. Hotel yang kami pilih juga sudah terbiasa menerima tamu Muslim. Informasi masjid terdekat dibagikan pada briefing hari pertama.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button" aria-expanded="false">Saya berangkat dari luar Jakarta, bagaimana?</button>
        <div class="faq-a"><p>Paket lengkap berangkat dari Jakarta (CGK). Untuk peserta dari luar Jakarta, kami menyarankan paket tanpa tiket agar Anda bisa mengatur rute sendiri, atau tiba di Jakarta sehari sebelum keberangkatan.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button" aria-expanded="false">Apakah saya perlu bisa bahasa Mandarin?</button>
        <div class="faq-a"><p>Tidak. Setiap kunjungan sekolah didampingi penerjemah. Di area expo, sebagian besar exhibitor internasional berbahasa Inggris.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button" aria-expanded="false">Apakah ada sertifikat?</button>
        <div class="faq-a"><p>Peserta menerima sertifikat program dari JAGATRIP beserta dokumentasi lengkap kunjungan. Sertifikat dari penyelenggara expo sedang kami usahakan dan akan dikonfirmasi lebih lanjut.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button" aria-expanded="false">Bagaimana kalau kuota sudah penuh?</button>
        <div class="faq-a"><p>Kami membuka daftar tunggu. Kursi JAGATRIP #1 habis sebelum tenggat pendaftaran ditutup, jadi kami sarankan mendaftar minat lebih awal — mendaftar minat belum mengikat Anda untuk membayar.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button" aria-expanded="false">Kalau saya batal berangkat?</button>
        <div class="faq-a"><p>Ketentuan pembatalan dan pengembalian dana dijelaskan pada kontrak peserta yang dikirim setelah pendaftaran resmi. Silakan tanyakan ke admin sebelum melakukan pembayaran.</p></div>
      </div>
    </div>
  </div>
</section>


