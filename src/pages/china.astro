---
import BaseLayout from '../layouts/BaseLayout.astro';

const eventSchema = {"@context": "https://schema.org", "@type": "Event", "name": "JAGATRIP #2 — Beijing & Hangzhou Education Mission", "startDate": "2026-09-11", "endDate": "2026-09-17", "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode", "eventStatus": "https://schema.org/EventScheduled", "location": [{"@type": "Place", "name": "Beijing, China"}, {"@type": "Place", "name": "Hangzhou, China"}], "organizer": {"@type": "Organization", "name": "PT Jagatrip Mitra Edukasi", "url": "https://jagatrip.com"}};
---

<BaseLayout title="JAGATRIP #2 — Education Mission ke Beijing & Hangzhou" description="Program studi banding pendidikan ke Beijing & Hangzhou, 11–17 September 2026. Dua expo internasional, kunjungan sekolah, kuota 20 peserta." canonical="https://jagatrip.com/china" ogType="website" extraSchemas={[eventSchema]}>





<main id="main">
<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="logo-wrap" aria-label="JAGATRIP"><img class="brand-logo" src="/images/china/jagatrip-logo.png" width="2094" height="570" alt="JAGATRIP Mitra Edukasi"></a>
    <a href="#form" class="nav-cta">Daftar Minat →</a>
  </div>
</nav>




<section class="hero" id="hero">
  <div class="hero-inner">
    <div class="hero-eyebrow">
      <span class="red-dot"></span> PROGRAM MENDATANG · JAGATRIP #2
    </div>
    <h1>Beijing &amp; Hangzhou <span class="accent">Education Mission</span></h1>
    <p class="hero-sub">Tujuh hari di dua kota Tiongkok. Dua pameran pendidikan internasional. Ruang kelas sekolah yang umumnya tertutup bagi pengunjung umum.</p>

    <div class="hero-meta">
      <div class="hero-meta-chip">📅 <strong>11 – 17 September 2026</strong></div>
