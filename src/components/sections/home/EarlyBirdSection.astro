---
import { SITE } from '../../../data/site';

const waLink = `https://wa.me/${SITE.waNumber}?text=${encodeURIComponent('Halo admin, saya mau daftar Early Bird JAGATRIP Malaysia-Thailand (24-28 Juni 2026). Mohon info lebih lanjut. Terimakasih.')}`;
---

<section class="py-16 md:py-24 bg-jaga-bg border-t border-gray-200">
  <div class="max-w-3xl mx-auto px-6">
    <div class="bg-linear-to-br from-gray-900 to-gray-800 rounded-4xl p-8 md:p-14 text-center text-white relative overflow-hidden shadow-2xl">

      <!-- Decorative -->
      <div class="absolute top-6 right-6 w-32 h-32 bg-jaga-orange/20 rounded-full blur-3xl"></div>
      <div class="absolute bottom-6 left-6 w-24 h-24 bg-jaga-orange/15 rounded-full blur-2xl"></div>

      <div class="relative z-10">
        <!-- Badge -->
        <span class="inline-block bg-jaga-orange text-white font-black text-xs md:text-sm uppercase tracking-[0.3em] px-5 py-2 rounded-full mb-6 shadow-lg">
          🔥 Potongan Khusus
        </span>

        <h2 class="text-2xl md:text-3xl font-black mb-2 leading-tight">
          untuk <span class="text-jaga-orange">10 Pendaftar Pertama</span>
        </h2>

        <!-- Pricing -->
        <div class="mt-8 mb-8">
          <p class="text-gray-400 text-lg line-through mb-1">Rp 7.000.000</p>
          <div class="flex items-center justify-center gap-3">
            <span class="text-sm font-bold uppercase tracking-wider text-jaga-orange">Early Bird</span>
            <span class="text-5xl md:text-6xl font-black text-white tracking-tight">Rp 6.500.000</span>
          </div>
          <p class="text-gray-400 text-sm mt-2">per orang · All-in</p>
        </div>

        <!-- CTA -->
        <a
          href={waLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-jaga-orange hover:bg-jaga-orange-600 text-white font-black text-base md:text-lg px-10 py-4 rounded-full shadow-xl hover:shadow-2xl transition-all transform hover:-translate-y-1"
        >
          Amankan Sekarang →
        </a>

        <p class="text-gray-500 text-xs mt-4">Kuota terbatas — hanya 10 slot</p>
      </div>
    </div>
  </div>
</section>
